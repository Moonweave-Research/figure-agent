def _memory_index(argv: list[str]) -> int:
    import quality_memory_index

    parser = argparse.ArgumentParser(prog="fig-agent memory-index")
    scope = parser.add_mutually_exclusive_group(required=True)
    scope.add_argument("--fixture")
    scope.add_argument("--suite")
    parser.add_argument("--write", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args(argv)
    try:
        if args.fixture:
            name = _validated_fixture_name(parser, args.fixture)
            payload = quality_memory_index.build_fixture_index(
                name,
                write=args.write,
                plugin_root=_paths().plugin_root,
                workspace_root=_paths().workspace_root,
            )
        else:
            suite = _validated_fixture_name(parser, args.suite)
            payload = quality_memory_index.build_suite_index(
                suite,
                write=args.write,
                plugin_root=_paths().plugin_root,
                workspace_root=_paths().workspace_root,
            )
    except (ValueError, quality_memory_index.QualityMemoryIndexError) as exc:
        print(f"fig-agent memory-index: {exc}", file=sys.stderr)
        return 1
    print(json.dumps(payload, indent=2, sort_keys=True))
    return 0


