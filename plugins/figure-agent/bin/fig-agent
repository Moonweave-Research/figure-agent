def _design_dogfood(argv: list[str]) -> int:
    import design_dogfood_packet
    import fig_driver
    import fig_queue

    parser = argparse.ArgumentParser(prog="fig-agent design-dogfood")
    parser.add_argument("name")
    parser.add_argument("--mode", choices=list(fig_driver.MODES), default="review")
    parser.add_argument("--goal", default="human-gated design dogfood")
    parser.add_argument("--output")
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--format", choices=("json",), default=None)
    args = parser.parse_args(argv)
    name = _validated_fixture_name(parser, args.name)
    queue = fig_queue.build_queue(
        repo_root=_paths().workspace_root,
        mode=args.mode,
        goal=args.goal,
        fixtures=[name],
    )
    packet = design_dogfood_packet.build_design_dogfood_packet(
        name,
        queue=queue,
        mode=args.mode,
        goal=args.goal,
    )
    text = json.dumps(packet, indent=2, sort_keys=True) + "\n"
    if args.output:
        output_path = Path(args.output)
        output_path.parent.mkdir(parents=True, exist_ok=True)
        output_path.write_text(text, encoding="utf-8")
    print(text, end="")
    return 0


def _bounded_tikz_refinement(argv: list[str]) -> int:
    import bounded_tikz_refinement_packet
    import fig_driver
    import fig_queue
    import style_benchmark_comparison
    import style_benchmark_pack

    parser = argparse.ArgumentParser(prog="fig-agent bounded-tikz-refinement")
    parser.add_argument("name")
    parser.add_argument("--mode", choices=list(fig_driver.MODES), default="review")
    parser.add_argument("--goal", default="bounded TikZ refinement request")
    parser.add_argument("--output")
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--format", choices=("json",), default=None)
    args = parser.parse_args(argv)
    name = _validated_fixture_name(parser, args.name)
    paths = _paths()
    queue = fig_queue.build_queue(
        repo_root=paths.workspace_root,
        mode=args.mode,
        goal=args.goal,
        fixtures=[name],
    )
    rows = queue.get("rows")
    queue_row = rows[0] if isinstance(rows, list) and rows else None
    style_pack = style_benchmark_pack.load_pack(
        name,
        plugin_root=paths.plugin_root,
        workspace_root=paths.workspace_root,
    )
    try:
        comparison = style_benchmark_comparison.load_comparison(
            name,
            plugin_root=paths.plugin_root,
            workspace_root=paths.workspace_root,
        )
    except style_benchmark_comparison.StyleBenchmarkComparisonError as exc:
        comparison = {"state": "missing" if str(exc) == "comparison_missing" else "invalid"}
    packet = bounded_tikz_refinement_packet.build_bounded_tikz_refinement_packet(
        name,
        style_pack=style_pack,
        comparison=comparison,
        queue_row=queue_row,
    )
    text = json.dumps(packet, indent=2, sort_keys=True) + "\n"
    if args.output:
        output_path = Path(args.output)
        output_path.parent.mkdir(parents=True, exist_ok=True)
        output_path.write_text(text, encoding="utf-8")
    print(text, end="")
    return 0


def _bounded_tikz_request_packet(
    name: str,
    *,
    mode: str,
    goal: str,
) -> dict[str, object]:
    import bounded_tikz_refinement_packet
    import fig_queue
    import style_benchmark_comparison
    import style_benchmark_pack

    paths = _paths()
    queue = fig_queue.build_queue(
        repo_root=paths.workspace_root,
        mode=mode,
        goal=goal,
        fixtures=[name],
    )
    rows = queue.get("rows")
    queue_row = rows[0] if isinstance(rows, list) and rows else None
    style_pack = style_benchmark_pack.load_pack(
        name,
        plugin_root=paths.plugin_root,
        workspace_root=paths.workspace_root,
    )
    try:
        comparison = style_benchmark_comparison.load_comparison(
            name,
            plugin_root=paths.plugin_root,
            workspace_root=paths.workspace_root,
        )
    except style_benchmark_comparison.StyleBenchmarkComparisonError as exc:
        comparison = {"state": "missing" if str(exc) == "comparison_missing" else "invalid"}
    return bounded_tikz_refinement_packet.build_bounded_tikz_refinement_packet(
        name,
        style_pack=style_pack,
        comparison=comparison,
        queue_row=queue_row,
    )


def _bounded_tikz_candidate(argv: list[str]) -> int:
    import bounded_tikz_candidate_packet
    import fig_driver

    parser = argparse.ArgumentParser(prog="fig-agent bounded-tikz-candidate")
    parser.add_argument("name")
    parser.add_argument("--mode", choices=list(fig_driver.MODES), default="review")
    parser.add_argument("--goal", default="bounded TikZ candidate packet")
    parser.add_argument("--output")
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--format", choices=("json",), default=None)
    args = parser.parse_args(argv)
    name = _validated_fixture_name(parser, args.name)
    request_packet = _bounded_tikz_request_packet(
        name,
        mode=args.mode,
        goal=args.goal,
    )
    packet = bounded_tikz_candidate_packet.build_bounded_tikz_candidate_packet(
        name,
        workspace_root=_paths().workspace_root,
        request_packet=request_packet,
    )
    text = json.dumps(packet, indent=2, sort_keys=True) + "\n"
    if args.output:
        output_path = Path(args.output)
        output_path.parent.mkdir(parents=True, exist_ok=True)
        output_path.write_text(text, encoding="utf-8")
    print(text, end="")
    return 0


def _bounded_tikz_apply(argv: list[str]) -> int:
    import bounded_tikz_candidate_apply
    import bounded_tikz_candidate_packet
    import fig_driver

    parser = argparse.ArgumentParser(prog="fig-agent bounded-tikz-apply")
    parser.add_argument("name")
    mode = parser.add_mutually_exclusive_group(required=True)
    mode.add_argument("--dry-run", action="store_true")
    mode.add_argument("--apply", action="store_true")
    parser.add_argument("--authorization")
    parser.add_argument("--mode", choices=list(fig_driver.MODES), default="review")
    parser.add_argument("--goal", default="bounded TikZ candidate apply")
    parser.add_argument("--output")
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--format", choices=("json",), default=None)
    args = parser.parse_args(argv)
    name = _validated_fixture_name(parser, args.name)
    paths = _paths()
    request_packet = _bounded_tikz_request_packet(
        name,
        mode=args.mode,
        goal=args.goal,
    )
    candidate_packet = bounded_tikz_candidate_packet.build_bounded_tikz_candidate_packet(
        name,
        workspace_root=paths.workspace_root,
        request_packet=request_packet,
    )
    source_mutation_decision = None
    if args.authorization:
        try:
            source_mutation_decision = json.loads(
                Path(args.authorization).read_text(encoding="utf-8")
            )
        except (OSError, json.JSONDecodeError) as exc:
            print(f"fig-agent bounded-tikz-apply: authorization_invalid:{exc}", file=sys.stderr)
            return 1
    try:
        result = bounded_tikz_candidate_apply.apply_bounded_tikz_candidate(
            name,
            workspace_root=paths.workspace_root,
            candidate_packet=candidate_packet,
            source_mutation_decision=source_mutation_decision,
            apply=args.apply,
        )
    except bounded_tikz_candidate_apply.BoundedTikzCandidateApplyError as exc:
        print(f"fig-agent bounded-tikz-apply: {exc}", file=sys.stderr)
        return 1
    text = json.dumps(result, indent=2, sort_keys=True) + "\n"
    if args.output:
        output_path = Path(args.output)
        output_path.parent.mkdir(parents=True, exist_ok=True)
        output_path.write_text(text, encoding="utf-8")
    print(text, end="")
    return 0 if result.get("status") in {"ready", "applied"} else 1


def main(argv: list[str] | None = None) -> int:
    if argv is None:
        _maybe_reexec_with_uv_project()
    args = list(argv if argv is not None else sys.argv[1:])
    if not args:
        print(
            "usage: fig-agent <doctor|status|compile|export|adjudicate|loop|closeout|helper> ...",
            file=sys.stderr,
        )
        return 2
    command, rest = args[0], args[1:]
    if command == "doctor":
        return _doctor(rest)
    if command == "status":
        return _status(rest)
    if command == "compile":
        return _compile(rest)
    if command == "export":
        return _export(rest)
    if command == "adjudicate":
        return _adjudicate(rest)
    if command == "loop":
        return _loop(rest)
    if command == "run":
        return _script_main("fig_run", rest)
    if command == "drive":
        return _script_main("fig_driver", rest)
    if command == "queue":
        import fig_queue

        return fig_queue.main(rest, repo_root=_paths().workspace_root)
    if command == "queue-run":
        import fig_queue_run

        return fig_queue_run.main(rest, repo_root=_paths().workspace_root)
    if command == "improve":
        return _script_main("fig_improve", rest)
    if command == "e2e-smoke":
        return _script_process("fig_e2e_smoke.py", rest)
    if command == "closeout":
        return _closeout(rest)
    if command == "helper":
        return _helper(rest)
    if command == "text-boundary":
        return _text_boundary(rest)
    if command == "quality-map":
        return _quality_map(rest)
    if command == "context-pack":
        return _context_pack(rest)
    if command == "memory-log":
        return _memory_log(rest)
    if command == "memory-index":
        return _memory_index(rest)
    if command == "benchmark-list":
        return _benchmark_list(rest)
    if command == "benchmark-run":
        return _benchmark_run(rest)
    if command == "benchmark-compare":
        return _benchmark_compare(rest)
    if command == "quality-next-experiment":
        return _quality_next_experiment(rest)
    if command == "next":
        return _next(rest)
    if command == "benchmark-detectors":
        return _benchmark_detectors(rest)
    if command == "propose":
        return _propose(rest)
    if command == "intent":
        return _intent(rest)
    if command == "analyze-panel":
        return _analyze_panel(rest)
    if command == "candidates":
        return _candidates(rest)
    if command.startswith("compose-"):
        import composition_cli

        result = composition_cli.dispatch(command, rest, paths=_paths())
        if result != 2:
            return result
    if command == "analyze-composition":
        return _analyze_composition(rest)
    if command == "lint-composition":
        return _lint_composition(rest)
    if command == "render-candidates":
        return _render_candidates(rest)
    if command == "rank-candidates":
        return _rank_candidates(rest)
    if command == "review-candidate":
        return _review_candidate(rest)
    if command == "compare-candidate":
        return _compare_candidate(rest)
    if command == "apply-candidate-ready":
        return _apply_candidate_ready(rest)
    if command == "accept-candidate":
        return _accept_candidate(rest)
    if command == "apply-candidate":
        return _apply_candidate(rest)
    if command == "attest":
        return _attest(rest)
    if command == "plan-check":
        return _plan_check(rest)
    if command == "evidence-sync":
        return _evidence_sync(rest)
    if command == "closeout-ready":
        return _closeout_ready(rest)
    if command == "closeout-accept":
        return _closeout_accept(rest)
    if command == "apply-plan":
        return _apply_plan(rest)
    if command == "verify-plan":
        return _verify_plan(rest)
    if command == "design-dogfood":
        return _design_dogfood(rest)
    if command == "bounded-tikz-refinement":
        return _bounded_tikz_refinement(rest)
    if command == "bounded-tikz-candidate":
        return _bounded_tikz_candidate(rest)
    if command == "bounded-tikz-apply":
        return _bounded_tikz_apply(rest)
    print(f"fig-agent: unknown command {command!r}", file=sys.stderr)
    return 2


if __name__ == "__main__":
    sys.exit(main())
