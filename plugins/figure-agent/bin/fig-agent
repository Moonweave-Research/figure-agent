def _load_fixture_json(name: str, fixture_path: str) -> dict:
    import candidate_contracts

    try:
        path = candidate_contracts.fixture_local_output_path(
            _paths().workspace_root,
            name,
            fixture_path,
        )
        payload = json.loads(path.read_text(encoding="utf-8"))
    except (
        OSError,
        json.JSONDecodeError,
        ValueError,
        candidate_contracts.CandidateContractError,
    ) as exc:
        raise RuntimeError(str(exc)) from exc
    if not isinstance(payload, dict):
        raise RuntimeError("expected JSON object")
    return payload


def _render_candidates(argv: list[str]) -> int:
    import candidate_render

    parser = argparse.ArgumentParser(prog="fig-agent render-candidates")
    parser.add_argument("name")
    parser.add_argument("--candidate-set", required=True)
    parser.add_argument("--candidate-id")
    parser.add_argument("--compile", action="store_true")
    parser.add_argument("--export", action="store_true")
    parser.add_argument("--crop-panel")
    parser.add_argument("--evaluate", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args(argv)
    name = _validated_fixture_name(parser, args.name)
    paths = _paths()
    try:
        candidate_set = _load_fixture_json(name, args.candidate_set)
        payload = candidate_render.render_candidate_set(
            name,
            candidate_set,
            plugin_root=paths.plugin_root,
            workspace_root=paths.workspace_root,
            candidate_set_path=Path(args.candidate_set),
            candidate_id=args.candidate_id,
            compile=args.compile,
            export=args.export,
            crop_panel=args.crop_panel,
            evaluate=args.evaluate,
        )
    except (RuntimeError, candidate_render.CandidateRenderError) as exc:
        print(f"fig-agent render-candidates: {exc}", file=sys.stderr)
        return 1
    print(json.dumps(payload, indent=2, sort_keys=True))
    return 0


def _rank_candidates(argv: list[str]) -> int:
    import candidate_contracts
    import candidate_rank
    import fixture_identity

    parser = argparse.ArgumentParser(prog="fig-agent rank-candidates")
    parser.add_argument("name")
    parser.add_argument("--candidate-set", required=True)
    parser.add_argument("--use-memory", action="store_true")
    parser.add_argument("--json", action="store_true")
    args = parser.parse_args(argv)
    name = _validated_fixture_name(parser, args.name)
    try:
        candidate_set = _load_fixture_json(name, args.candidate_set)
        memory_index = _load_memory_index(name) if args.use_memory else None
        scores = []
        for candidate in candidate_set.get("candidates", []):
            if not isinstance(candidate, dict):
                continue
            candidate_id = str(candidate.get("id"))
            fixture_identity.validate_fixture_name(candidate_id)
            manifest = _load_fixture_json(
                name,
                f"build/candidates/{candidate_id}/candidate_manifest.json",
            )
            try:
                render_manifest = _load_fixture_json(
                    name,
                    f"build/candidates/{candidate_id}/render_manifest.json",
                )
            except RuntimeError:
                render_manifest = None
            scores.append(
                candidate_rank.score_manifest(
                    manifest,
                    candidate=candidate,
                    render_manifest=render_manifest,
                    memory_index=memory_index,
                )
            )
    except (
        RuntimeError,
        ValueError,
        candidate_contracts.CandidateContractError,
    ) as exc:
        print(f"fig-agent rank-candidates: {exc}", file=sys.stderr)
        return 1
    scores.sort(key=lambda score: (-float(score["rank_score"]), str(score["candidate_id"])))
    payload = {
        "schema": "figure-agent.candidate-rank-result.v1",
        "fixture": name,
        "scores": scores,
    }
    print(json.dumps(payload, indent=2, sort_keys=True))
    return 0


def _load_memory_index(name: str) -> dict | None:
    import candidate_contracts

    paths = _paths()
    example_dir = paths.examples_dir / name
    build_dir = example_dir / "build"
    memory_dir = build_dir / "memory"
    for label, path in (("build", build_dir), ("memory", memory_dir)):
        if path.is_symlink():
            raise RuntimeError(f"memory_index_symlink_forbidden: {label}")
    path = candidate_contracts.fixture_local_output_path(
        paths.workspace_root,
        name,
        "build/memory/quality_memory_index.json",
    )
    if path.is_symlink():
        raise RuntimeError("memory_index_symlink_forbidden: output")
    if not path.is_file():
        return None
    payload = json.loads(path.read_text(encoding="utf-8"))
    if not isinstance(payload, dict):
        raise RuntimeError("memory_index_invalid")
    return payload


