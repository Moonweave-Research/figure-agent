%% --- 2D trap-level schematic primitives ---
%% \TrapLevel{x}{y}{line-style}: horizontal trap state plus electron marker.
%% The third argument accepts a TikZ style or color expression.
\newcommand{\TrapLevel}[3]{%
  \draw[#3] (#1-0.18,#2) -- (#1+0.22,#2);
  \node[
    circle,
    draw=cBlue!75!black,
    fill=cBlue!45,
    inner sep=0pt,
    minimum size=1.35mm,
    line width=0.34pt
  ] at (#1,#2+0.13) {};
}

%% --- Fixed-view isometric schematic contract ---
%% Projection basis:
%%   x axis = (1.00cm, 0.00cm)
%%   y axis = (0.45cm, 0.28cm)
%%   z axis = (0.00cm, 1.00cm)
%% Use for schematic depth cues only. This is not a general 3D camera.
%% Note: \IsoBlock defines named coordinates isoA-isoH inside \begingroup..\endgroup,
%% but TikZ named coordinates are global. Sequential \IsoBlock calls overwrite them
%% (fine). Do not nest \IsoBlock calls inside another's 5th-arg hook -- silent
%% coordinate collisions will result.
\tikzset{
  iso basis/.style={
    x={(1.00cm,0.00cm)},
    y={(0.45cm,0.28cm)},
    z={(0.00cm,1.00cm)}
  },
  iso front face/.style={draw=cGray!80!black, line width=0.45pt, fill=#1!28},
  iso top face/.style={draw=cGray!80!black, line width=0.45pt, fill=#1!18},
  iso side face/.style={draw=cGray!80!black, line width=0.45pt, fill=#1!38},
  iso edge/.style={draw=cGray!85!black, line width=0.55pt},
  iso hidden edge/.style={draw=cGray!45, line width=0.35pt, dashed},
  iso label/.style={font=\fontsize{7}{8.4}\selectfont, text=cGray!90!black},
  iso callout/.style={draw=cGray!70, line width=0.35pt, -{Stealth[length=3pt,width=2pt]}},
  iso charge/.style={draw=cBlue!80!black, fill=cBlue!70, line width=0.25pt},
  iso exposed/.style={draw=cGray!80!black, line width=0.45pt, fill=#1!12},
}

% \IsoBlock{w}{d}{h}{color}{hook}: isometric block (W x D x H) at origin; #5 is TikZ code executed inside the iso group.
\newcommand{\IsoBlock}[5]{%
  \begingroup
  \def\isow{#1}%
  \def\isod{#2}%
  \def\isoh{#3}%
  \def\isocolor{#4}%
  \coordinate (isoA) at (0,0,0);
  \coordinate (isoB) at (\isow,0,0);
  \coordinate (isoC) at (\isow,\isod,0);
  \coordinate (isoD) at (0,\isod,0);
  \coordinate (isoE) at (0,0,\isoh);
  \coordinate (isoF) at (\isow,0,\isoh);
  \coordinate (isoG) at (\isow,\isod,\isoh);
  \coordinate (isoH) at (0,\isod,\isoh);
  \path[iso side face=\isocolor] (isoB) -- (isoC) -- (isoG) -- (isoF) -- cycle;
  \path[iso front face=\isocolor] (isoA) -- (isoB) -- (isoF) -- (isoE) -- cycle;
  \path[iso top face=\isocolor] (isoE) -- (isoF) -- (isoG) -- (isoH) -- cycle;
  \draw[iso edge] (isoA) -- (isoB) -- (isoC) -- (isoG) -- (isoH) -- (isoE) -- cycle;
  \draw[iso edge] (isoB) -- (isoF) -- (isoG);
  \draw[iso edge] (isoE) -- (isoF);
  \draw[iso hidden edge] (isoA) -- (isoD) -- (isoC);
  \draw[iso hidden edge] (isoD) -- (isoH);
  #5%
  \endgroup
}

% \IsoCharge{x,y,sign}: half-buried hemisphere charge dot (★★★ v0.2 promotion)
% Spec §8.
\newcommand{\IsoCharge}[1]{%
  \IsoChargeDraw#1\relax
}
\def\IsoChargeDraw#1,#2,#3\relax{%
  \begin{scope}
    \pgfmathsetmacro{\ICRADIUS}{0.12}%
    \fill[iso charge] (#1,#2) +(-\ICRADIUS,0)
      arc[start angle=180, end angle=360, radius=\ICRADIUS] -- cycle;
    \node[font=\tiny\bfseries, white] at (#1,#2) {$#3$};
  \end{scope}%
}

% \GradSlab{x,y,w,h,c1,c2,axis}: rectangular slab with x/y color gradient.
\newcommand{\GradSlab}[1]{%
  \GradSlabDraw#1\relax
}
\makeatletter
\def\GradSlabDraw#1,#2,#3,#4,#5,#6,#7\relax{%
  \begingroup
  \edef\GSAxis{\zap@space#7 \@empty}%
  \def\GSXAxis{x}%
  \ifx\GSAxis\GSXAxis
    \path[draw=cGray!80!black, line width=0.45pt, shade,
      left color=#5!35, right color=#6!35] (#1,#2) rectangle ++(#3,#4);
  \else
    \path[draw=cGray!80!black, line width=0.45pt, shade,
      bottom color=#5!35, top color=#6!35] (#1,#2) rectangle ++(#3,#4);
  \fi
  \endgroup
}
\makeatother

% \IsoConeTip{x,y,direction}: triangular tip emphasis face.
\newcommand{\IsoConeTip}[1]{%
  \IsoConeTipDraw#1\relax
}
\makeatletter
\def\IsoConeTipDraw#1,#2,#3\relax{%
  \begingroup
  \edef\ICTDir{\zap@space#3 \@empty}%
  \def\ICTRight{right}%
  \def\ICTLeft{left}%
  \def\ICTUp{up}%
  \def\ICTDown{down}%
  \ifx\ICTDir\ICTRight
    \path[draw=cGray!80!black, line width=0.45pt, fill=cAmberSphere!75]
      (#1,#2) -- ++(-0.30,0.16) -- ++(0,-0.32) -- cycle;
  \else\ifx\ICTDir\ICTLeft
    \path[draw=cGray!80!black, line width=0.45pt, fill=cAmberSphere!75]
      (#1,#2) -- ++(0.30,0.16) -- ++(0,-0.32) -- cycle;
  \else\ifx\ICTDir\ICTUp
    \path[draw=cGray!80!black, line width=0.45pt, fill=cAmberSphere!75]
      (#1,#2) -- ++(-0.16,-0.30) -- ++(0.32,0) -- cycle;
  \else\ifx\ICTDir\ICTDown
    \path[draw=cGray!80!black, line width=0.45pt, fill=cAmberSphere!75]
      (#1,#2) -- ++(-0.16,0.30) -- ++(0.32,0) -- cycle;
  \else
    \PackageError{polymer-paper-preamble}{Invalid IsoConeTip direction `#3'}{Use right, left, up, or down.}%
  \fi\fi\fi\fi
  \endgroup
}
\makeatother

%% --- Phase 1.2 bbox macros (Layer 3) ---
%% Lifted styles + macros for log-log plots, band diagrams, bell curves, polymer chains.
%% Sources: docs/macro-audit.md (ranked LOC-saved); call sites in
%% golden_trap_depth_picture, fig3_n2_evidence, fig3_trap_schematic_v97.
\tikzset{
  tickLabel/.style={
    font=\sffamily\fontsize{4.3}{5.2}\selectfont,
    text=cGray!90!black
  },
  bandbox/.style={
    draw=black, line width=0.45pt, fill=cLGray!30,
    minimum width=1.55cm, minimum height=0.48cm
  },
  bandFrame/.style={cTeal, line width=1.2pt, rounded corners=4pt},
  bandAxis/.style={-{Stealth[length=3.2pt,width=2.4pt]}, cGray, line width=0.42pt},
  bandEt/.style={cGray!45, dashed, line width=0.38pt},
  trapShallow/.style={cAmber, line width=0.72pt},
  trapDeep/.style={cBlue!45!cRed, line width=0.72pt},
}

% \BandBox{x}{y}{label}: filled cLGray rectangle node used as CB or VB block.
\providecommand{\BandBox}[3]{%
  \node[bandbox] at (#1,#2) {#3};
}

% \BellCurve{x1,y1,x2,y2,color,orientation}: symmetric bell lobe inside bbox; orientation in {up, side}; fill <color>!18, stroke <color>!80!black 0.8pt.
\newcommand{\BellCurve}[1]{%
  \BellCurveDraw#1\relax
}
\makeatletter
\def\BellCurveDraw#1,#2,#3,#4,#5,#6\relax{%
  \begingroup
  \edef\BCorient{\zap@space#6 \@empty}%
  \def\BCup{up}%
  \def\BCside{side}%
  \pgfmathsetmacro{\BCw}{(#3)-(#1)}%
  \pgfmathsetmacro{\BCh}{(#4)-(#2)}%
  \ifdim\BCw pt<0.001pt\relax\endgroup\else
  \ifdim\BCh pt<0.001pt\relax\endgroup\else
    \ifx\BCorient\BCup
      \path[draw=#5!80!black, line width=0.8pt, fill=#5!18]
        (#1,#2)
        .. controls (#1+0.207*\BCw,#2+0.043*\BCh)
                and (#1+0.264*\BCw,#2+0.986*\BCh)
        .. (#1+0.494*\BCw,#4)
        .. controls (#1+0.724*\BCw,#4)
                and (#1+0.747*\BCw,#2+0.058*\BCh)
        .. (#3,#2) -- cycle;
    \else\ifx\BCorient\BCside
      \path[draw=#5!80!black, line width=0.8pt, fill=#5!18]
        (#1,#2)
        .. controls (#1+0.043*\BCw,#2+0.207*\BCh)
                and (#1+0.986*\BCw,#2+0.264*\BCh)
        .. (#3,#2+0.494*\BCh)
        .. controls (#3,#2+0.724*\BCh)
                and (#1+0.058*\BCw,#2+0.747*\BCh)
        .. (#1,#4) -- cycle;
    \else
      \PackageError{polymer-paper-preamble}{Invalid BellCurve orientation `#6'}{Use up or side.}%
    \fi\fi
    \endgroup
  \fi\fi
}
\makeatother

% \WavyChain{x1,x2,y,style,S_csv,trap_csv}: polymer chain row; style in zigzag or sin; zigzag amp=0.17 period~0.30; sin amp=0.40 (1.5 periods); brace-wrap S_csv and trap_csv at call site (commas inside).
\newcommand{\WavyChain}[1]{%
  \WavyChainDraw#1\relax
}
\makeatletter
\def\WavyChainDraw#1,#2,#3,#4,#5,#6\relax{%
  \begingroup
  \edef\WCstyle{\zap@space#4 \@empty}%
  \def\WCzigzag{zigzag}%
  \def\WCsin{sin}%
  \def\WCempty{}%
  \ifx\WCstyle\WCzigzag
    \def\WCamp{0.17}%
    \pgfmathtruncatemacro{\WCnsteps}{max(2,round(((#2)-(#1))/0.30))}%
    \xdef\WCcoords{}%
    \foreach \WCk in {0,...,\WCnsteps} {%
      \pgfmathsetmacro{\WCxk}{(#1)+\WCk*((#2)-(#1))/\WCnsteps}%
      \pgfmathsetmacro{\WCyk}{(#3)+ifthenelse(mod(\WCk,2)==0,0,\WCamp)}%
      \xdef\WCcoords{\WCcoords (\WCxk,\WCyk)}%
    }%
    \draw[cGray, line width=0.85pt] plot[smooth] coordinates {\WCcoords};
  \else\ifx\WCstyle\WCsin
    \def\WCamp{0.40}%
    \draw[cGray!75!black, line width=0.7pt]
      plot[smooth, samples=80, domain=0:1]
      ({(#1)+\x*((#2)-(#1))},{(#3)+\WCamp*sin(\x*540)});
  \else
    \PackageError{polymer-paper-preamble}{Invalid WavyChain style `#4'}{Use zigzag or sin.}%
  \fi\fi
  \edef\WCSlist{\zap@space#5 \@empty}%
  \ifx\WCSlist\WCempty\else
    \foreach \WCsx in {#5} {%
      \node[text=cAmber, font=\sffamily\fontsize{6.5}{7.8}\selectfont]
        at (\WCsx,#3+\WCamp+0.28) {S};
      \draw[cAmber, fill=white, line width=0.50pt]
        (\WCsx,#3+\WCamp+0.12) circle (0.042cm);
    }%
  \fi
  \edef\WCTlist{\zap@space#6 \@empty}%
  \ifx\WCTlist\WCempty\else
    \foreach \WCtx in {#6} {%
      \node[circle, fill=cBlue!55, draw=cBlue!80!black,
            inner sep=0pt, minimum size=2mm, line width=0.4pt]
        at (\WCtx,#3+\WCamp+0.10) {};
    }%
  \fi
  \endgroup
}
\makeatother

% \BandDiagram{x1,y1,x2,y2,cb_y,vb_y,et_x,shallow_ys,deep_ys}: rounded teal frame + CB/VB bandboxes + Energy axis + dashed Et + \TrapLevel dashes; brace-wrap shallow_ys and deep_ys at call site (commas inside).
\newcommand{\BandDiagram}[1]{%
  \BandDiagramDraw#1\relax
}
\makeatletter
\def\BandDiagramDraw#1,#2,#3,#4,#5,#6,#7,#8,#9\relax{%
  \begingroup
  \pgfmathsetmacro{\BDcx}{(#1+#3)/2}%
  \pgfmathsetmacro{\BDaxX}{#1+0.63}%
  \pgfmathsetmacro{\BDaxYlo}{#6+0.05}%
  \pgfmathsetmacro{\BDaxYhi}{#5-0.43}%
  \pgfmathsetmacro{\BDaxYmid}{(\BDaxYlo+\BDaxYhi)/2}%
  \pgfmathsetmacro{\BDetYlo}{#6-0.35}%
  \pgfmathsetmacro{\BDetYhi}{#5+0.30}%
  \draw[bandFrame] (#1,#2) rectangle (#3,#4);
  \BandBox{\BDcx}{#5}{CB}
  \BandBox{\BDcx}{#6}{VB}
  \draw[bandAxis] (\BDaxX,\BDaxYlo) -- (\BDaxX,\BDaxYhi);
  \node[rotate=90, text=cGray, font=\sffamily\fontsize{6.5}{7.8}\selectfont]
    at (\BDaxX-0.18,\BDaxYmid) {Energy};
  \draw[bandEt] (#7,\BDetYlo) -- (#7,\BDetYhi);
  \node[text=cGray] at (#7+0.20,\BDaxYmid) {$E_t$};
  \foreach \BDy in {#8} { \TrapLevel{\BDcx-0.41}{\BDy}{trapShallow} }%
  \foreach \BDy in {#9} { \TrapLevel{\BDcx-0.25}{\BDy}{trapDeep} }%
  \endgroup
}
\makeatother

% \LogLogPlot{x0,y0,x1,y1}{xticks}{xlabels}{yticks}{ylabels}{xlabel}{ylabel}: log-log axes + ticks + labels at given bbox; bbox is comma-CSV, rest brace args; tick lists are pos-only (xticks/yticks) or pos/label pairs (xlabels/ylabels).
\newcommand{\LogLogPlot}[7]{%
  \LLPParseBox#1\relax{#2}{#3}{#4}{#5}{#6}{#7}%
}
\makeatletter
\def\LLPParseBox#1,#2,#3,#4\relax{%
  \def\LLPxa{#1}\def\LLPya{#2}\def\LLPxb{#3}\def\LLPyb{#4}%
  \LLPDraw
}
\newcommand{\LLPDraw}[6]{%
  \begingroup
  \draw[cGray, line width=0.38pt, -{Stealth[length=2.5pt,width=1.8pt]}]
    (\LLPxa,\LLPya) -- (\LLPxb,\LLPya);
  \draw[cGray, line width=0.38pt, -{Stealth[length=2.5pt,width=1.8pt]}]
    (\LLPxa,\LLPya) -- (\LLPxa,\LLPyb);
  \foreach \LLPxi in {#1} {
    \draw[cGray, line width=0.25pt] (\LLPxi,\LLPya) -- (\LLPxi,\LLPya-0.06);
  }
  \foreach \LLPxi/\LLPlab in {#2} {
    \node[tickLabel, anchor=north] at (\LLPxi,\LLPya-0.12) {$\LLPlab$};
  }
  \foreach \LLPyi in {#3} {
    \draw[cGray, line width=0.25pt] (\LLPxa,\LLPyi) -- (\LLPxa-0.06,\LLPyi);
  }
  \foreach \LLPyi/\LLPlab in {#4} {
    \node[tickLabel, anchor=east] at (\LLPxa-0.12,\LLPyi) {$\LLPlab$};
  }
  \node[font=\sffamily\fontsize{5.5}{6.6}\selectfont, text=cGray]
    at ({(\LLPxa+\LLPxb)/2},\LLPya-0.27) {#5};
  \node[font=\sffamily\fontsize{5.5}{6.6}\selectfont, text=cGray, rotate=90]
    at (\LLPxa-0.32,{(\LLPya+\LLPyb)/2}) {#6};
  \endgroup
}
\makeatother
