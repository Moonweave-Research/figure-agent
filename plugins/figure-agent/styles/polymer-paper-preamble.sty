% \BandBox{x}{y}{label}: filled cLGray rectangle node used as CB or VB block.
\providecommand{\BandBox}[3]{%
  \node[bandbox] at (#1,#2) {#3};
}

% \PlotCallout[<node style>]{target coord}{label coord}{text}: white-backed plot annotation
% with a short leader arrow. Coordinates may be plain TikZ or pgfplots axis coords.
\newcommand{\PlotCallout}[4][]{%
  \draw[plotCalloutLine] #3 -- #2;
  \node[plotCalloutLabel, #1] at #3 {#4};
}

% \BellCurve[<style keys>]{x1,y1,x2,y2,orientation}: symmetric bell-lobe shape primitive.
% Geometry: bbox (x1,y1)-(x2,y2); orientation in {up, side}.
% Style: caller supplies draw/fill/line width via the optional [#1] pgfkeys list,
% or via \tikzset{bell curve/.append style={...}} for figure-wide consistency.
% Default `bell curve/.style` is outline-only with palette-neutral cGray; the `fill`
% key is intentionally omitted (TikZ semantic — see design spec §"Empirically validated").
\tikzset{
  bell curve/.style={
    draw=cGray,
    line width=0.5pt,
  },
}
\makeatletter
\newcommand{\BellCurve}[2][]{%
  \BellCurve@parse[#1]#2\relax
}
\def\BellCurve@parse[#1]#2,#3,#4,#5,#6\relax{%
  \pgfmathsetmacro{\BC@w}{(#4)-(#2)}%
  \pgfmathsetmacro{\BC@h}{(#5)-(#3)}%
  \edef\BC@orient{\zap@space#6 \@empty}%
  \def\BC@up{up}\def\BC@side{side}%
  \ifx\BC@orient\BC@up
    \path[bell curve, #1]
      (#2,#3)
      .. controls (#2+0.207*\BC@w,#3+0.043*\BC@h)
              and (#2+0.264*\BC@w,#3+0.986*\BC@h)
      .. (#2+0.494*\BC@w,#5)
      .. controls (#2+0.724*\BC@w,#5)
              and (#2+0.747*\BC@w,#3+0.058*\BC@h)
      .. (#4,#3) -- cycle;
  \else\ifx\BC@orient\BC@side
    \path[bell curve, #1]
      (#2,#3)
      .. controls (#2+0.043*\BC@w,#3+0.207*\BC@h)
              and (#2+0.986*\BC@w,#3+0.264*\BC@h)
      .. (#4,#3+0.494*\BC@h)
      .. controls (#4,#3+0.724*\BC@h)
              and (#2+0.058*\BC@w,#3+0.747*\BC@h)
      .. (#2,#5) -- cycle;
  \else
    \PackageError{polymer-paper-preamble}{Invalid BellCurve orientation `#6'}{Use up or side.}%
  \fi\fi
}
\makeatother

% \WavyChain{x1,x2,y,style,S_csv,trap_csv}: polymer chain row; style in zigzag or sin; zigzag amp=0.17 period~0.30; sin amp=0.40 (1.5 periods); brace-wrap S_csv and trap_csv at call site (commas inside).
\newcommand{\WavyChain}[1]{%
  \WavyChainDraw#1\relax
}
\makeatletter
\def\WavyChainDraw#1,#2,#3,#4,#5,#6\relax{%
  \begingroup
  \edef\WCstyle{\zap@space#4 \@empty}%
  \def\WCzigzag{zigzag}%
  \def\WCsin{sin}%
  \def\WCempty{}%
  \ifx\WCstyle\WCzigzag
    \def\WCamp{0.17}%
    \pgfmathtruncatemacro{\WCnsteps}{max(2,round(((#2)-(#1))/0.30))}%
    \xdef\WCcoords{}%
    \foreach \WCk in {0,...,\WCnsteps} {%
      \pgfmathsetmacro{\WCxk}{(#1)+\WCk*((#2)-(#1))/\WCnsteps}%
      \pgfmathsetmacro{\WCyk}{(#3)+ifthenelse(mod(\WCk,2)==0,0,\WCamp)}%
      \xdef\WCcoords{\WCcoords (\WCxk,\WCyk)}%
    }%
    \draw[cGray, line width=0.85pt] plot[smooth] coordinates {\WCcoords};
  \else\ifx\WCstyle\WCsin
    \def\WCamp{0.40}%
    \draw[cGray!75!black, line width=0.7pt]
      plot[smooth, samples=80, domain=0:1]
      ({(#1)+\x*((#2)-(#1))},{(#3)+\WCamp*sin(\x*540)});
  \else
    \PackageError{polymer-paper-preamble}{Invalid WavyChain style `#4'}{Use zigzag or sin.}%
  \fi\fi
  \edef\WCSlist{\zap@space#5 \@empty}%
  \ifx\WCSlist\WCempty\else
    \foreach \WCsx in {#5} {%
      \node[text=cAmber, font=\sffamily\fontsize{6.5}{7.8}\selectfont]
        at (\WCsx,#3+\WCamp+0.28) {S};
      \draw[cAmber, fill=white, line width=0.50pt]
        (\WCsx,#3+\WCamp+0.12) circle (0.042cm);
    }%
  \fi
  % Per-iteration empty check: prior outer empty checks (\zap@space, \detokenize,
  % \ifblank) all failed because the macro arg #6 = " {}" (space + empty group)
  % is not normalizable to "empty" by any of these without leading-space trimming.
  % \foreach happily produces one iteration with a blank \WCtx for input {} or "",
  % so we filter inside the loop body via \edef + \ifx against \WCempty.
  \foreach \WCtx in {#6} {%
    \edef\WCtxcheck{\WCtx}%
    \ifx\WCtxcheck\WCempty\else
      \node[circle, fill=cBlue!55, draw=cBlue!80!black,
            inner sep=0pt, minimum size=2mm, line width=0.4pt]
        at (\WCtx,#3+\WCamp+0.10) {};
    \fi
  }%
  \endgroup
}
\makeatother

% \BandDiagram[<style keys>]{x1,y1,x2,y2,cb_y,vb_y,et_x,shallow_ys,deep_ys}: rounded teal frame + CB/VB bandboxes + Energy axis + dashed Et + \TrapLevel dashes. Optional [#1] passes pgfkeys to the wrapping `band diagram` style key (default empty). \BD@opts storage avoids LaTeX 9-slot \def limit; \begingroup placement isolates the option per-call. Boolean keys: [no_et] suppresses bandEt dashed line + auto $E_t$ text node (et_x slot still required); [traps=none] suppresses all \TrapLevel calls (shallow_ys/deep_ys slots can be empty {}).
\makeatletter
\newcommand{\BandDiagram}[2][]{%
  \begingroup
  \def\BD@opts{#1}%
  \BandDiagramDraw#2\relax
}
\def\BandDiagramDraw#1,#2,#3,#4,#5,#6,#7,#8,#9\relax{%
  \begin{scope}[band diagram]
  \BDnoEtfalse
  \BDnoTrapsfalse
  \expandafter\tikzset\expandafter{\BD@opts}%
  \pgfmathsetmacro{\BDcx}{(#1+#3)/2}%
  \pgfmathsetmacro{\BDaxX}{#1+0.63}%
  \pgfmathsetmacro{\BDaxYlo}{#6+0.05}%
  \pgfmathsetmacro{\BDaxYhi}{#5-0.43}%
  \pgfmathsetmacro{\BDaxYmid}{(\BDaxYlo+\BDaxYhi)/2}%
  \pgfmathsetmacro{\BDetYlo}{#6-0.35}%
  \pgfmathsetmacro{\BDetYhi}{#5+0.30}%
  \draw[bandFrame] (#1,#2) rectangle (#3,#4);
  \BandBox{\BDcx}{#5}{CB}
  \BandBox{\BDcx}{#6}{VB}
  \draw[bandAxis] (\BDaxX,\BDaxYlo) -- (\BDaxX,\BDaxYhi);
  \node[rotate=90, text=cGray, font=\sffamily\fontsize{6.5}{7.8}\selectfont]
    at (\BDaxX-0.18,\BDaxYmid) {Energy};
  \ifBDnoEt\else
    \draw[bandEt] (#7,\BDetYlo) -- (#7,\BDetYhi);
    \node[text=cGray] at (#7+0.20,\BDaxYmid) {$E_t$};
  \fi
  \ifBDnoTraps\else
    \foreach \BDy in {#8} { \TrapLevel{\BDcx-0.41}{\BDy}{trapShallow} }%
    \foreach \BDy in {#9} { \TrapLevel{\BDcx-0.25}{\BDy}{trapDeep} }%
  \fi
  \end{scope}
  \endgroup
}
\makeatother

% \LogLogPlot{x0,y0,x1,y1}{xticks}{xlabels}{yticks}{ylabels}{xlabel}{ylabel}: log-log axes + ticks + labels at given bbox; bbox is comma-CSV, rest brace args; tick lists are pos-only (xticks/yticks) or pos/label pairs (xlabels/ylabels); xlabel/ylabel content must be wrapped in $...$ at call site if it contains math operators (e.g. {$\log\,t$}).
\newcommand{\LogLogPlot}[7]{%
  \LLPParseBox#1\relax{#2}{#3}{#4}{#5}{#6}{#7}%
}
\makeatletter
\def\LLPParseBox#1,#2,#3,#4\relax{%
  \def\LLPxa{#1}\def\LLPya{#2}\def\LLPxb{#3}\def\LLPyb{#4}%
  \LLPDraw
}
\newcommand{\LLPDraw}[6]{%
  \begingroup
  \draw[cGray, line width=0.38pt, -{Stealth[length=2.5pt,width=1.8pt]}]
    (\LLPxa,\LLPya) -- (\LLPxb,\LLPya);
  \draw[cGray, line width=0.38pt, -{Stealth[length=2.5pt,width=1.8pt]}]
    (\LLPxa,\LLPya) -- (\LLPxa,\LLPyb);
  \foreach \LLPxi in {#1} {
    \draw[cGray, line width=0.25pt] (\LLPxi,\LLPya) -- (\LLPxi,\LLPya-0.06);
  }
  \foreach \LLPxi/\LLPlab in {#2} {
    \node[tickLabel, anchor=north] at (\LLPxi,\LLPya-0.12) {$\LLPlab$};
  }
  \foreach \LLPyi in {#3} {
    \draw[cGray, line width=0.25pt] (\LLPxa,\LLPyi) -- (\LLPxa-0.06,\LLPyi);
  }
  \foreach \LLPyi/\LLPlab in {#4} {
    \node[tickLabel, anchor=east] at (\LLPxa-0.12,\LLPyi) {$\LLPlab$};
  }
  \node[font=\sffamily\fontsize{5.5}{6.6}\selectfont, text=cGray]
    at ({(\LLPxa+\LLPxb)/2},\LLPya-0.27) {#5};
  \node[font=\sffamily\fontsize{5.5}{6.6}\selectfont, text=cGray, rotate=90]
    at (\LLPxa-0.32,{(\LLPya+\LLPyb)/2}) {#6};
  \endgroup
}
\makeatother
